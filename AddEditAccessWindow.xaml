<Window x:Class="EAccess.Client.AddEditAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись допуска"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Color x:Key="PrimaryColor1">#F54B64</Color>
        <Color x:Key="PrimaryColor2">#F78361</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="OverlayBrush" Color="#B3000000"/>
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PrimaryColor1}" Offset="0"/>
            <GradientStop Color="{StaticResource PrimaryColor2}" Offset="1"/>
        </LinearGradientBrush>
        <FontFamily x:Key="AppFont">pack://application:,,,/EAccess.Client;component/fonts/#Ali-Bold</FontFamily>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}" Height="78" Width="{TemplateBinding Width}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="#40465A" CornerRadius="10" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Dropdown" TargetType="ComboBox">
            <Setter Property="Background" Value="#40465A"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" CornerRadius="10" Background="#40465A" BorderBrush="Transparent" BorderThickness="0"/>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="False" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter/>
                            </ToggleButton>
                            <ContentPresenter Margin="12,0,32,0" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{TemplateBinding SelectionBoxItem}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#40465A" CornerRadius="10" Padding="6" BorderBrush="#555C6D" BorderThickness="1">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource OverlayBrush}">
        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="24" Padding="32" Width="937" Height="654" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Верхняя полоса: логотип, паспорт, аккредитация, кнопка сохранить -->
                <Grid Grid.Row="0" Margin="0,0,0,18" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,24,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png" Width="175" Height="153" Stretch="Uniform"/>
                        <TextBlock Text="Страж" Style="{StaticResource LabelText}" FontSize="36" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top" Margin="0,4,16,0">
                        <TextBlock Text="Паспорт:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="PassportTextBox" Style="{StaticResource InputBox}" Width="414" MaxLength="10" PreviewTextInput="DigitsOnly_PreviewTextInput" TextChanged="PassportTextBox_TextChanged" HorizontalContentAlignment="Left" HorizontalAlignment="Left"/>

                        <TextBlock Text="Аккредитация:" Style="{StaticResource LabelText}" Margin="0,10,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                            <TextBlock Text="С" Style="{StaticResource LabelText}" FontSize="22" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox x:Name="AccredStartTextBox" Style="{StaticResource InputBox}" Width="165" MaxLength="10" PreviewTextInput="DigitsOnly_PreviewTextInput" TextChanged="DateTextBox_TextChanged" Margin="0,0,5,0"/>
                            <TextBlock Text="по" Style="{StaticResource LabelText}" FontSize="22" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox x:Name="AccredEndTextBox" Style="{StaticResource InputBox}" Width="187" MaxLength="10" PreviewTextInput="DigitsOnly_PreviewTextInput" TextChanged="DateTextBox_TextChanged"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2" x:Name="SaveButton" Content="Сохранить" Style="{StaticResource ActionButton}" Width="220" Height="78" Click="SaveButton_Click" VerticalAlignment="Top" Margin="0,12,0,0"/>
                </Grid>

                <!-- Основные поля -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Фамилия:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="LastNameTextBox" Style="{StaticResource InputBox}" Width="407" HorizontalAlignment="Left"/>

                        <TextBlock Text="Отчество:" Style="{StaticResource LabelText}" Margin="0,10,0,0"/>
                        <TextBox x:Name="MiddleNameTextBox" Style="{StaticResource InputBox}" Width="406" HorizontalAlignment="Left"/>

                        <TextBlock Text="Телефон:" Style="{StaticResource LabelText}" Margin="0,10,0,0"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
                            <Border Height="52" Width="15" Padding="0" Margin="0,0,10,0">
                                <TextBlock Text="8" Style="{StaticResource LabelText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
                            </Border>
                            <TextBox x:Name="PhoneTextBox" Style="{StaticResource InputBox}" Width="382" MaxLength="10" PreviewTextInput="DigitsOnly_PreviewTextInput" HorizontalContentAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="Имя:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="FirstNameTextBox" Style="{StaticResource InputBox}" Width="406" HorizontalAlignment="Left"/>

                        <TextBlock Text="Должность:" Style="{StaticResource LabelText}" Margin="0,10,0,0"/>
                        <ComboBox x:Name="PositionComboBox" Style="{StaticResource Dropdown}" Width="404" DisplayMemberPath="Name" SelectedValuePath="Id" HorizontalAlignment="Left"/>

                        <Button x:Name="CancelButton" Content="Отмена" Style="{StaticResource ActionButton}" Width="220" Height="78" Click="CancelButton_Click" Margin="0,36,0,0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>