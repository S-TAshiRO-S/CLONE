<Window x:Class="EAccess.Client.AddEditPurchaseItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция сметы"
        Width="900" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="FieldBrush" Color="#4E586E"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#555C6D"/>
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PrimaryColor1}" Offset="0"/>
            <GradientStop Color="{StaticResource PrimaryColor2}" Offset="1"/>
        </LinearGradientBrush>

        

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="26"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NiceComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="18"
                                    BorderBrush="{StaticResource GridLineBrush}"
                                    BorderThickness="1"/>

                            <ContentPresenter Margin="14,0,44,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                            <ToggleButton x:Name="Tg"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Right"
                                          Width="44"
                                          FocusVisualStyle="{x:Null}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ArrowBd"
                                                Background="Transparent"
                                                CornerRadius="0,18,18,0">
                                            <Path Data="M 0 0 L 8 8 L 16 0 Z"
                                                  Fill="White"
                                                  Stretch="Uniform"
                                                  Width="14" Height="10"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ArrowBd" Property="Background" Value="#303543"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ArrowBd" Property="Background" Value="#303543"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource FieldBrush}"
                                        CornerRadius="14"
                                        BorderBrush="{StaticResource GridLineBrush}"
                                        BorderThickness="1"
                                        Margin="0,6,0,0"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="MinHeight" Value="38"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd" Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter Margin="6,2,6,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#303543"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#353B4A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="25" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
                           Width="110" Height="96" Margin="0,0,0,8"/>
                    <TextBlock Text="Страж"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="Отмена" Style="{StaticResource Btn}" Click="Cancel_Click" Margin="0,0,24,0"/>
                    <Button Content="Сохранить" Style="{StaticResource Btn}" Click="Save_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="Наименование:" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameTextBox" Style="{StaticResource InputTextBox}" Margin="0,0,0,14"/>

                    <TextBlock Text="Цена:" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PriceTextBox"
                             Style="{StaticResource InputTextBox}"
                             PreviewTextInput="Money_PreviewTextInput"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Статус:" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="StatusComboBox"
                              Style="{StaticResource NiceComboBox}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <TextBlock Text="Поставщик:" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                    <TextBox x:Name="SupplierTextBox" Style="{StaticResource InputTextBox}" Margin="0,0,0,14"/>

                    <TextBlock Text="Количество:" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="QuantityTextBox"
                                 Style="{StaticResource InputTextBox}"
                                 Width="260"
                                 PreviewTextInput="DigitsOnly_PreviewTextInput"/>
                        <TextBlock Text="ед"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>