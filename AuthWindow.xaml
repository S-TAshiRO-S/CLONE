<Window x:Class="EAccess.Client.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EAccess.Client"
        Title="Авторизация"
        Width="1244" Height="792"
        MinWidth="1244" MinHeight="792"
        MaxWidth="1244" MaxHeight="792"
        WindowState="Normal"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#2A2E3A">

    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PrimaryColor1}" Offset="0"/>
            <GradientStop Color="{StaticResource PrimaryColor2}" Offset="1"/>
        </LinearGradientBrush>
        <!-- Стили -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="28"/>
        </Style>

        <Style x:Key="SmallLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="72"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <local:TextEmptyAndNotFocusedToVisibilityConverter x:Key="PlaceholderConverter"/>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="60">

            <!-- Логотип -->
            <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
                   Width="310" Height="235" RenderTransformOrigin="0.227,0.448"/>

            <!-- Заголовок -->
            <TextBlock Text="Страж" FontFamily="{StaticResource AppFont}" FontSize="96"
                       Foreground="{StaticResource WhiteBrush}" HorizontalAlignment="Center" Margin="0,0,0,24" FontWeight="Bold"/>

            <!-- Форма: две колонки -->
            <Grid HorizontalAlignment="Stretch" Margin="120,0,120,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Левая колонка -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Stretch">
                    <TextBlock Text="Логин:" Style="{StaticResource SmallLabelStyle}" FontSize="48" FontWeight="Bold"/>
                    <Border x:Name="LoginBorder" Background="{StaticResource DarkGreyBrush}" CornerRadius="18"
                            Padding="18" Height="56">
                        <Grid>
                            <TextBox x:Name="LoginTextBox" Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center" FontFamily="{StaticResource AppFont}"
                                     Foreground="{StaticResource WhiteBrush}" FontSize="20"/>
                            <TextBlock Text="Введите логин" IsHitTestVisible="False" VerticalAlignment="Center" Margin="6,0,0,0"
                                       FontFamily="{StaticResource AppFont}" FontSize="20" Foreground="#9BA3B3" Height="20">
                                <TextBlock.Visibility>
                                    <MultiBinding Converter="{StaticResource PlaceholderConverter}">
                                        <Binding ElementName="LoginTextBox" Path="Text"/>
                                        <Binding ElementName="LoginTextBox" Path="IsFocused"/>
                                    </MultiBinding>
                                </TextBlock.Visibility>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Правая колонка -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Stretch">
                    <TextBlock Text="Пароль:" Style="{StaticResource SmallLabelStyle}" FontSize="48" FontWeight="Bold"/>
                    <Border x:Name="PasswordBorder" Background="{StaticResource DarkGreyBrush}" CornerRadius="18"
                            Padding="18" Height="56">
                        <Grid>
                            <PasswordBox x:Name="PasswordBox" Background="Transparent" BorderThickness="0"
                                         VerticalContentAlignment="Center" FontFamily="{StaticResource AppFont}"
                                         Foreground="{StaticResource WhiteBrush}" FontSize="20"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus"/>
                            <TextBlock x:Name="PasswordPlaceholder" Text="Введите пароль"
                                       VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="{StaticResource AppFont}"
                                       FontSize="20" Foreground="#9BA3B3" MouseDown="PasswordPlaceholder_MouseDown"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Большая кнопка -->
            <Border HorizontalAlignment="Center" CornerRadius="25" Margin="0,56,0,50"
                    Width="450" Height="90" Background="{StaticResource PrimaryGradient}">
                <Button x:Name="LoginButton" Click="Login_Click" Style="{StaticResource LoginButtonStyle}" Content="Вход"
                        Width="300"/>
            </Border>

        </StackPanel>
    </Grid>
</Window>
