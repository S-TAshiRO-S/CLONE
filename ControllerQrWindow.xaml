<Window x:Class="EAccess.Client.ControllerQrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR / Штрих код"
        Width="1244" Height="792"
        MinWidth="1244" MinHeight="792"
        MaxWidth="1244" MaxHeight="792"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#2A2E3A"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewTextInput="Window_PreviewTextInput"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Color x:Key="PrimaryColor1">#F54B64</Color>
        <Color x:Key="PrimaryColor2">#F78361</Color>
        <LinearGradientBrush x:Key="PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F54B64" Offset="0"/>
            <GradientStop Color="#F78361" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="DarkGreyBrush" Color="#4E586E"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#2ECA8E"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#E2605D"/>
        <SolidColorBrush x:Key="NeutralBrush" Color="#5A6172"/>
        <FontFamily x:Key="AppFont">pack://application:,,,/EAccess.Client;component/fonts/#Ali-Bold</FontFamily>

        <Style x:Key="PrimaryRoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarMenuButton" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="38"/>
        </Style>

        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical" Margin="0,20,0,30">
                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
                           Width="175" Height="153" Margin="30,0,0,10"/>
                    <TextBlock Text="Страж" FontFamily="{StaticResource AppFont}" FontSize="48"
                               Foreground="{StaticResource WhiteBrush}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="30,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnMain" Content="Главная" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnMain_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnAccessList" Content="Список допусков" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnAccessList_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnQrBarcode" Content="QR / Штрих код" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnQrBarcode_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnAudit" Content="Аудит" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnAudit_Click" Height="64" Width="300" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1" Background="{StaticResource SecondaryBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="UserFullNameTextBlock" Grid.Row="0" Text="Фамилия Имя Отчество"
                           FontFamily="{StaticResource AppFont}" FontSize="36" Foreground="{StaticResource WhiteBrush}"
                           FontWeight="Bold" HorizontalAlignment="Right" Margin="0,20,20,20"/>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="640">
                    <TextBlock Text="Отсканируйте QR или штрих-код"
                               Style="{StaticResource LabelText}" FontSize="32" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Border x:Name="ScanPlaceholderBorder" Background="#3A3F50" CornerRadius="16" Padding="28" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12">
                            <Rectangle Height="5" Fill="#E25959" RadiusX="2" RadiusY="2" Width="320" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                            <TextBlock Text="Сканируйте код"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource WhiteBrush}"
                                       FontFamily="{StaticResource AppFont}" FontSize="28"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ResultBorder" Padding="12,10" CornerRadius="10" Background="Transparent"
        Visibility="Collapsed" BorderBrush="Transparent" BorderThickness="0" Margin="0,0,0,6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="ДОСТУП"
                   FontFamily="{StaticResource AppFont}" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,14" TextAlignment="Center"/>
                            <TextBlock x:Name="FullNameText" Text="Фамилия Имя Отчество: -"
                                       Style="{StaticResource InfoText}" FontSize="28" Margin="0,0,0,8" TextAlignment="Center"/>
                            <TextBlock x:Name="PositionText" Text="Должность: -"
                                       Style="{StaticResource InfoText}" FontSize="26" Margin="0,0,0,8" TextAlignment="Center"/>
                            <TextBlock x:Name="PassportText" Text="Паспорт: -"
                                       Style="{StaticResource InfoText}" FontSize="26" Margin="0,0,0,8" TextAlignment="Center"/>
                            <TextBlock x:Name="AccreditationText" Text="Аккредитация: -"
                                       Style="{StaticResource InfoText}" FontSize="26" Margin="0,0,0,10" TextAlignment="Center"/>
                            <TextBlock x:Name="NoteText" Text=""
                                       Style="{StaticResource InfoText}" FontSize="22" Opacity="0.92" TextWrapping="Wrap"
                                       Margin="0,0,0,4" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="HiddenInput" Opacity="0" Focusable="True" Width="1" Height="1"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             KeyboardNavigation.TabNavigation="Cycle"
                             IsTabStop="False"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
