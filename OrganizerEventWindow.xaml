<Window x:Class="EAccess.Client.OrganizerEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мероприятие" Width="1244" Height="792"
        MinWidth="1244" MinHeight="792"
        MaxWidth="1244" MaxHeight="792"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#2A2E3A">
    <Window.Resources>
        <Color x:Key="PrimaryColor1">#F54B64</Color>
        <Color x:Key="PrimaryColor2">#F78361</Color>
        <LinearGradientBrush x:Key="PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F54B64" Offset="0"/>
            <GradientStop Color="#F78361" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="DarkGreyBrush" Color="#4E586E"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <FontFamily x:Key="AppFont">pack://application:,,,/EAccess.Client;component/fonts/#Ali-Bold</FontFamily>

        <Style x:Key="PrimaryRoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartEventButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarMenuButton" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="38"/>
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
            <Setter Property="FontSize" Value="24"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource DarkGreyBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="2"
                                          Focusable="False"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical" Margin="0,20,0,30">
                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
                           Width="175" Height="153" Margin="30,0,0,10"/>
                    <TextBlock Text="Страж" FontFamily="{StaticResource AppFont}" FontSize="48"
                               Foreground="{StaticResource WhiteBrush}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="30,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnMain" Content="Главная" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnMain_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnBudget" Content="Смета" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnBudget_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnReports" Content="Отчёты" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnReports_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnAudit" Content="Аудит" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnAudit_Click" Height="64" Width="300" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1" Background="{StaticResource SecondaryBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="UserFullNameTextBlock" Grid.Row="0" Text="Фамилия Имя Отчество"
                           FontFamily="{StaticResource AppFont}" FontSize="36" Foreground="{StaticResource WhiteBrush}"
                           FontWeight="Bold" HorizontalAlignment="Right" Margin="0,20,20,20"/>

                <Grid Grid.Row="1" Margin="20,20,20,20" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="EventTitleText" Grid.Row="0" Text="Название мероприятия" Style="{StaticResource LabelText}"
                               HorizontalAlignment="Center" Margin="0,0,0,0"/>

                    <Grid Grid.Row="2" Width="760" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Даты проведения: с" Style="{StaticResource SmallLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="StartDateTextBox" Height="52" Style="{StaticResource InputBox}"
                                 LostFocus="StartDateTextBox_LostFocus"
                                 PreviewTextInput="DateTextBox_PreviewTextInput"
                                 TextChanged="DateTextBox_TextChanged"
                                 DataObject.Pasting="DateTextBox_Pasting"
                                 MaxLength="10"/>
                        <TextBlock Grid.Column="4" Text="по" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Grid.Column="6" x:Name="EndDateTextBox" Height="52" Style="{StaticResource InputBox}"
                                 LostFocus="EndDateTextBox_LostFocus"
                                 PreviewTextInput="DateTextBox_PreviewTextInput"
                                 TextChanged="DateTextBox_TextChanged"
                                 DataObject.Pasting="DateTextBox_Pasting"
                                 MaxLength="10"/>
                    </Grid>

                    <Grid Grid.Row="4" Width="760" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Место проведения:" Style="{StaticResource SmallLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="LocationTextBox" Height="52" Style="{StaticResource InputBox}"
                                 LostFocus="LocationTextBox_LostFocus"/>
                    </Grid>

                </Grid>
            </Grid>
            <Button x:Name="EndEventButton" Content="Закончить мероприятие" Width="350" Height="64"
                    Style="{StaticResource StartEventButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,65,50" Click="EndEventButton_Click"/>
        </Grid>
    </Grid>
</Window>