<Window x:Class="EAccess.Client.MainOrganizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Главное (Организатор)"
        Width="1244" Height="792"
        MinWidth="1244" MinHeight="792"
        MaxWidth="1244" MaxHeight="792"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#2A2E3A">

    <Window.Resources>
        <!-- Цвета -->
        <Color x:Key="PrimaryColor1">#F54B64</Color>
        <Color x:Key="PrimaryColor2">#F78361</Color>
        <SolidColorBrush x:Key="PrimaryGradientBrush">
            <SolidColorBrush.Color>
                <!-- временный однотонный; ниже используем LinearGradientBrush в стиле кнопки -->
                #F54B64
            </SolidColorBrush.Color>
        </SolidColorBrush>
        <LinearGradientBrush x:Key="PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F54B64" Offset="0"/>
            <GradientStop Color="#F78361" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="SecondaryBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="DarkGreyBrush" Color="#4E586E"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>

        <!-- Шрифт (если App.xaml уже содержит AppFont, можно убрать эту строку) -->
        <FontFamily x:Key="AppFont">pack://application:,,,/EAccess.Client;component/fonts/#Ali-Bold</FontFamily>

        <!-- Кнопка: стиль с градиентом и закруглениями -->
        <Style x:Key="PrimaryRoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- можно добавить Trigger-ы (MouseOver) при желании -->
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Большая правая кнопка (Начать мероприятие) -->
        <Style x:Key="StartEventButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Малые кнопки меню слева -->
        <Style x:Key="SidebarMenuButton" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

    </Window.Resources>

    <!-- Общая сетка: две колонки -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- логотип и заголовок -->
                    <RowDefinition Height="Auto"/>
                    <!-- отступ -->
                    <RowDefinition Height="*"/>
                    <!-- кнопки -->
                    <RowDefinition Height="Auto"/>
                    <!-- кнопка Начать мероприятие (левая колонка, но мы разместим справа) -->
                </Grid.RowDefinitions>

                <!-- Логотип и название -->
                <StackPanel Grid.Row="0"
            Orientation="Vertical"
            VerticalAlignment="Top"
            Margin="0,20,0,40"
            HorizontalAlignment="Left">

                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
           Width="175"
           Height="153"
           Margin="30,0,0,10"/>

                    <TextBlock Text="Страж"
               FontFamily="{StaticResource AppFont}"
               FontSize="48"
               Foreground="{StaticResource WhiteBrush}"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="30,0,0,0"/>
                </StackPanel>


                <!-- Блок кнопок -->
                <StackPanel Grid.Row="2" Margin="0,0,0,0">
                    <Button x:Name="BtnMain" Content="Главная" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnMain_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnBudget" Content="Смета" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnBudget_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnReports" Content="Отчёты" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnReports_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnAudit" Content="Аудит" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnAudit_Click" Height="64" Width="300" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,0" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- Правая рабочая область -->
        <Grid Grid.Column="1" Background="{StaticResource SecondaryBrush}">
            <!-- Верхняя панель: ФИО пользователя справа -->
            <Grid Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- пустое место слева для выравнивания -->
                <StackPanel Grid.Column="0"/>

                <!-- ФИО -->
                <TextBlock x:Name="UserFullNameTextBlock" Grid.Column="1" Text="Фамилия Имя Отчество"
                           FontFamily="{StaticResource AppFont}" FontSize="36" Foreground="{StaticResource WhiteBrush}"
                           FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,50,60
                           ,0"/>
            </Grid>

            <!-- Контент placeholder (в будущем сюда загрузим страницы) -->
            <Border Margin="32,88,32,88" Background="Transparent" CornerRadius="6" BorderBrush="#00000000">
                <!-- Тут будет основной контент -->
            </Border>

            <!-- Кнопка "Начать мероприятие" внизу справа -->
            <Button x:Name="BtnStartEvent" Content="Начать мероприятие" Width="320" Height="64"
                    Style="{StaticResource StartEventButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,65,50" Click="BtnStartEvent_Click"/>
        </Grid>
    </Grid>
</Window>
