<Window x:Class="EAccess.Client.SecurityAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Контроль / Аудит"
        Width="1244" Height="792"
        MinWidth="1244" MinHeight="792"
        MaxWidth="1244" MaxHeight="792"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#2A2E3A">
    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F54B64" Offset="0"/>
            <GradientStop Color="#F78361" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PrimaryRoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarMenuButton" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="TableHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Background" Value="#3A4050"/>
            <Setter Property="BorderBrush" Value="#707890"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid" x:Key="AuditGridStyle">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#555C6D"/>
            <Setter Property="VerticalGridLinesBrush" Value="#555C6D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555C6D"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="RowDetailsVisibilityMode" Value="Collapsed"/>
            <Setter Property="RowHeight" Value="{x:Static sys:Double.NaN}"/>
            <Setter Property="ClipboardCopyMode" Value="ExcludeHeader"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGrid">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="DG_ScrollViewer" Focusable="False">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <DataGridColumnHeadersPresenter Grid.Column="0" Grid.Row="0"/>
                                            <ScrollContentPresenter Grid.Column="0" Grid.Row="1" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="1" Orientation="Vertical"/>
                                            <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="2" Orientation="Horizontal"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical" Margin="0,20,0,30">
                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
                           Width="175" Height="153" Margin="30,0,0,10"/>
                    <TextBlock Text="Страж" FontFamily="{StaticResource AppFont}" FontSize="48"
                               Foreground="{StaticResource WhiteBrush}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="30,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnMain" Content="Главная" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnMain_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnAccessList" Content="Список допусков" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnAccessList_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnReports" Content="Отчёты" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnReports_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnControlAudit" Content="Контроль / Аудит" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnControlAudit_Click" Height="64" Width="300" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="30.5,10,0,0">
                        <Button x:Name="BtnExport" Width="160" Height="60" Style="{StaticResource PrimaryRoundedButton}" Click="BtnExport_Click"
                                ToolTip="Экспортировать текущий аудит в PDF">
                            <Image Source="pack://application:,,,/EAccess.Client;component/pictures/export.png" Width="55" Height="55"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1" Background="{StaticResource SecondaryBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="UserFullNameTextBlock" Grid.Row="0" Text="Фамилия Имя Отчество"
                           FontFamily="{StaticResource AppFont}" FontSize="36" Foreground="{StaticResource WhiteBrush}"
                           FontWeight="Bold" HorizontalAlignment="Right" Margin="0,20,20,20"/>

                <Border Grid.Row="1" Background="#333849" CornerRadius="18" Padding="16" Margin="20,0,20,14">
                    <StackPanel Orientation="Vertical" Margin="4,0,4,0">
                        <TextBlock Text="Поиск" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="SearchTextBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,4"
                                 TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#333849" CornerRadius="0" Padding="12" Margin="20,0,20,20">
                    <DataGrid x:Name="AuditDataGrid"
                              Style="{StaticResource AuditGridStyle}"
                              ItemsSource="{Binding FilteredAuditEntries}"
                              AlternationCount="2">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="MinHeight" Value="48"/>
                                <Setter Property="Height" Value="{x:Static sys:Double.NaN}"/>
                                <Setter Property="VerticalAlignment" Value="Top"/>
                                <Setter Property="Background" Value="#3B4252"/>
                                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                <Setter Property="BorderBrush" Value="#555C6D"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#343A49"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#5E6A82"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия Имя Отчество" Binding="{Binding UserFullName}" Width="260">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="TextAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="6,4,6,6"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Дата / Время" Binding="{Binding AuditDateTime}" Width="180">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="*">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="TextAlignment" Value="Left"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                        <Setter Property="Margin" Value="6,4,6,6"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>