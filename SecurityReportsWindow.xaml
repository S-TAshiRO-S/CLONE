<Window x:Class="EAccess.Client.SecurityReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёты"
        Width="1244" Height="792"
        MinWidth="1244" MinHeight="792"
        MaxWidth="1244" MaxHeight="792"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#2A2E3A">
    <Window.Resources>
        <Color x:Key="PrimaryColor1">#F54B64</Color>
        <Color x:Key="PrimaryColor2">#F78361</Color>
        <LinearGradientBrush x:Key="PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F54B64" Offset="0"/>
            <GradientStop Color="#F78361" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="DarkGreyBrush" Color="#4E586E"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <FontFamily x:Key="AppFont">pack://application:,,,/EAccess.Client;component/fonts/#Ali-Bold</FontFamily>

        <Style x:Key="PrimaryRoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarMenuButton" TargetType="Button" BasedOn="{StaticResource PrimaryRoundedButton}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="38"/>
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
            <Setter Property="FontSize" Value="24"/>
        </Style>

        <Style x:Key="TableHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid" x:Key="AccessListGridStyle">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="RowHeight" Value="48"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#555C6D"/>
            <Setter Property="VerticalGridLinesBrush" Value="#555C6D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555C6D"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="RowBackground" Value="#303543"/>
            <Setter Property="AlternatingRowBackground" Value="#353B4A"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4A5164"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#4A5164"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
            </Style.Resources>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#3A4050"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="#707890"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                        <Setter Property="Background" Value="#2F3442"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3D4457"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A5164"/>
                                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <DockPanel>
                                    <ContentPresenter Margin="10,0,28,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Path x:Name="Arrow"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{StaticResource WhiteBrush}"/>
                                </DockPanel>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   Focusable="False"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        Background="#2F3442"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.5"/>
                                <Setter Property="Foreground" Value="#B0B6C5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Background" Value="#3A4050"/>
            <Setter Property="BorderBrush" Value="#707890"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                    <Setter Property="Foreground" Value="#D0D4DF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical" Margin="0,20,0,30">
                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png"
                           Width="175" Height="153" Margin="30,0,0,10"/>
                    <TextBlock Text="Страж" FontFamily="{StaticResource AppFont}" FontSize="48"
                               Foreground="{StaticResource WhiteBrush}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="30,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnMain" Content="Главная" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnMain_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnAccessList" Content="Список допусков" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnAccessList_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnReports" Content="Отчёты" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnReports_Click" Width="300" Height="64" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <Button x:Name="BtnControlAudit" Content="Контроль / Аудит" Style="{StaticResource SidebarMenuButton}"
                            Click="BtnControlAudit_Click" Height="64" Width="300" FontWeight="Bold" FontSize="28" Margin="30.5,0,0,25"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="30.5,10,0,0">
                        <Button x:Name="BtnExport" Width="160" Height="60" Style="{StaticResource PrimaryRoundedButton}" Click="BtnExport_Click"
                                ToolTip="Экспортировать текущий набор в PDF и Excel">
                            <Image Source="pack://application:,,,/EAccess.Client;component/pictures/export.png" Width="55" Height="55"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1" Background="{StaticResource SecondaryBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="UserFullNameTextBlock" Grid.Row="0" Text="Фамилия Имя Отчество"
                           FontFamily="{StaticResource AppFont}" FontSize="36" Foreground="{StaticResource WhiteBrush}"
                           FontWeight="Bold" HorizontalAlignment="Right" Margin="0,20,20,20"/>

                <!-- Блок фильтров -->
                <Border Grid.Row="1" Background="#333849" CornerRadius="18" Padding="16" Margin="20,0,20,14">
                    <StackPanel Orientation="Vertical" Margin="0,2,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="Фильтр по:" Style="{StaticResource SmallLabel}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ReportModeComboBox" Width="210" Height="42" Style="{StaticResource DarkComboBoxStyle}"
                                      SelectionChanged="ReportModeComboBox_SelectionChanged"
                                      ItemsSource="{Binding ReportModes}" SelectedItem="{Binding SelectedReportMode, Mode=TwoWay}" Margin="10,0,0,0"/>
                        </StackPanel>

                        <StackPanel x:Name="DateFilterPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock Text="Дата с" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="StartDateTextBox" Width="130" Height="42" Style="{StaticResource FilterTextBox}" MaxLength="10"
                                     TextChanged="StartDateTextBox_TextChanged" PreviewTextInput="DateTextBox_PreviewTextInput"/>
                            <TextBlock Text="по" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" Margin="8,0,8,0"/>
                            <TextBox x:Name="EndDateTextBox" Width="130" Height="42" Style="{StaticResource FilterTextBox}" MaxLength="10"
                                     TextChanged="EndDateTextBox_TextChanged" PreviewTextInput="DateTextBox_PreviewTextInput"/>
                            <CheckBox x:Name="TodayOnlyCheckBox" Content="Только на сегодня" FontFamily="{StaticResource AppFont}" FontSize="16"
                                      Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="TodayOnlyCheckBox_Checked" Unchecked="TodayOnlyCheckBox_Checked"/>
                        </StackPanel>

                        <StackPanel x:Name="PositionFilterPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="Должности" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="PositionsComboBox" Width="260" Height="42" Style="{StaticResource DarkComboBoxStyle}"
                                      ItemsSource="{Binding PositionFilters}" IsEditable="True" IsReadOnly="True" StaysOpenOnEdit="True"
                                      IsDropDownOpen="False" DropDownClosed="PositionsComboBox_DropDownClosed">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Click="PositionCheckBox_Click" FontFamily="{StaticResource AppFont}" FontSize="16" Foreground="{StaticResource WhiteBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button x:Name="ClearPositionsButton" Content="Очистить" Style="{StaticResource PrimaryRoundedButton}" Width="120" Height="42"
                                    FontSize="16" Click="ClearPositionsButton_Click" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#333849" CornerRadius="18" Padding="12" Margin="20,10,20,20">
                    <DataGrid x:Name="AccessDataGrid" Style="{StaticResource AccessListGridStyle}" ItemsSource="{Binding FilteredEntries}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="150">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="170">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Паспорт" Binding="{Binding Passport}" Width="140">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="170">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Аккредитация" Binding="{Binding AccreditationRange}" Width="240">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                        <Setter Property="FontSize" Value="20"/>
                                        <Setter Property="Background" Value="#2A2E3A"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TableCell}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>