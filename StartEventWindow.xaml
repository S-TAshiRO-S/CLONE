<Window x:Class="EAccess.Client.StartEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Начало мероприятия"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="OverlayBrush" Color="#B3000000"/>
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PrimaryColor1}" Offset="0"/>
            <GradientStop Color="{StaticResource PrimaryColor2}" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PrimaryRoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource OverlayBrush}">
        <Border Background="{StaticResource SecondaryBrush}" CornerRadius="24" Padding="48,36" Width="777" Height="494" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Image Source="pack://application:,,,/EAccess.Client;component/pictures/logo.png" Width="175" Height="153" Margin="0,0,0,12"/>
                    <TextBlock Text="Страж" FontFamily="{StaticResource AppFont}" FontSize="48" FontWeight="Bold" Foreground="{StaticResource WhiteBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Название мероприятия:" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>

                <Border Grid.Row="2" Background="{StaticResource DarkGreyBrush}" CornerRadius="12" Padding="14" VerticalAlignment="Top" Height="55">
                    <TextBox x:Name="EventNameTextBox" Background="Transparent" BorderThickness="0" Foreground="{StaticResource WhiteBrush}"
                             FontFamily="{StaticResource AppFont}" FontSize="22" VerticalAlignment="Center" Height="30" />
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Сохранить" Width="210" Height="64" Style="{StaticResource PrimaryRoundedButton}" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>